{
  "name": "edge-opcua",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "node  --env-file=.env --loader ts-node/esm src/app.ts",
    "dev:pretty": "node --env-file=./.env --loader ts-node/esm src/app.ts | npx pino-pretty -t -c",
    "prebuild": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/app.js"
  },
  "keywords": [],
  "author": "Yan Yang",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "dotenv": "^17.3.1",
    "mqtt": "^5.15.0",
    "node-opcua-client": "^2.163.1",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/mqtt": "^0.0.34",
    "@types/node": "^25.3.3",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@peculiar/x509": {
      "typescript": "^5.0.0"
    }
  },
  "imports": {
    "#*": {
      "development": "./src/*/index.ts",
      "default": "./dist/*/index.js"
    }
  }
}
